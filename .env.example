# Vercel Postgres — se generan automáticamente al conectar la base de datos en Vercel
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Genera con: openssl rand -base64 32
JWT_SECRET=

# football-data.org — datos de partidos/resultados/plantillas
FOOTBALL_DATA_API_KEY=

# Secreto para proteger el endpoint de cron (debe coincidir con el header que llama Vercel Cron)
CRON_SECRET=

# Resend — envío de correos (verificación, recuperación de contraseña, soporte)
RESEND_API_KEY=
RESEND_FROM=
# Correo donde llegan los mensajes de soporte de los usuarios (no se muestra en la app)
SUPPORT_EMAIL=guessbet.admin@gmail.com

# Sentry — monitoreo de errores del servidor (opcional; si se omite, los errores solo quedan en los logs de Vercel)
SENTRY_DSN=

# Secreto para /api/admin/backup (descarga manual de un respaldo de la BD). Genera con: openssl rand -base64 32
BACKUP_SECRET=

# The Odds API (the-odds-api.com) — cuotas reales de Coolbet y 1xBet, plan gratis 500 creditos/mes.
# Si se omite, esos botones de "Usar cuotas reales de..." simplemente no aparecen (sin romper nada).
ODDS_API_KEY=

# OddsPapi (oddspapi.io) — cuotas reales de Betano. Experimental, no probado contra la API real todavia.
ODDSPAPI_API_KEY=

# Mercado Pago — cobro de suscripcion Premium (Checkout Pro). Usa el Access Token de PRODUCCION
# (no el de prueba) para cobrar de verdad. Si se omite, el boton "Hazte PRO" muestra error 503.
MP_ACCESS_TOKEN=

# API-Football (api-football.com) — marcador y minuto en vivo, plan gratis 100 requests/dia.
# Si se omite, el modo "En vivo" del analizador sigue siendo 100% manual (sin romper nada).
API_FOOTBALL_KEY=

# Web Push (notificaciones al celular cuando se confirma una alineacion). Generadas con
# lib/webPush.ts / el comando que use crypto de Node -- ver el chat para el valor ya generado.
# VAPID_PUBLIC_KEY debe tener el MISMO valor que NEXT_PUBLIC_VAPID_PUBLIC_KEY (la publica
# se expone al navegador a proposito, la privada NUNCA).
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:guessbet.admin@gmail.com
