# Vercel Postgres — se generan automáticamente al conectar la base de datos en Vercel
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Genera con: openssl rand -base64 32
JWT_SECRET=

# football-data.org — datos de partidos/resultados/plantillas
FOOTBALL_DATA_API_KEY=

# Secreto para proteger el endpoint de cron (debe coincidir con el header que llama Vercel Cron)
CRON_SECRET=

# Resend — envío de correos (verificación, recuperación de contraseña, soporte)
RESEND_API_KEY=
RESEND_FROM=
# Correo donde llegan los mensajes de soporte de los usuarios (no se muestra en la app)
SUPPORT_EMAIL=guessbet.admin@gmail.com

# Sentry — monitoreo de errores del servidor (opcional; si se omite, los errores solo quedan en los logs de Vercel)
SENTRY_DSN=
